{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python3 -c ' *)",
      "Bash(python -c ' *)",
      "Bash(python3 *)"
    ]
  },
  "hooks": {
    "Stop": [],
    "SessionEnd": [],
    "PostToolUse": [],
    "PreToolUse": []
  },
  "statusLine": {
    "type": "command",
    "command": "git rev-parse --abbrev-ref HEAD",
    "padding": 1
  }
}